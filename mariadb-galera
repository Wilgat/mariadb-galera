# ----------------------------- Project Constants -----------------------------

APP_NAME="mariadb-galera"
VERSION="1.4.0"
DESCRIPTION="MariaDB Galera Cluster installer + IP manager"

REPO_USER="Wilgat"
REPO_NAME="mariadb-galera"
SCRIPT_URL="https://raw.githubusercontent.com/${REPO_USER}/${REPO_NAME}/main/${APP_NAME}"

# ────────────────────────────────────────────────
# Safe variable defaults — repeated on purpose
# ────────────────────────────────────────────────

: "${GLOBAL_BIN:=/usr/local/bin}"
: "${USER_BIN:=${HOME}/.local/bin}"

: "${CONFIG_DIR:=/etc/mariadb-galera}"
: "${IP_CONF:=${CONFIG_DIR}/ip.conf}"

: "${MARIA_DB_VERSION:=11.8}"
: "${GALERA_PACKAGE:=galera-4}"

# ----------------------------- Root Detection --------------------------------
if [ -z "${IS_ROOT:-}" ]; then
    if [ "$(id -u)" -eq 0 ]; then
        IS_ROOT=1
    else
        IS_ROOT=0
    fi
fi

# ----------------------------- Force Flags & Quiet Mode ----------------------
: "${FORCE_REINSTALL:=0}"
: "${QUIET:=0}"

# ----------------------------- Color Output (Non-interactive Safe) -----------
if [ -t 1 ]; then
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    RED='\033[0;31m'
    NC='\033[0m'
else
    GREEN='' YELLOW='' RED='' NC=''
fi

# POSIX-safe logging functions
die() { printf >&2 "${RED}Error: %s${NC}\n" "$*"; exit 1; }
info()    { [ "${QUIET}" -eq 0 ] && printf "${GREEN}[INFO]${NC} %s\n" "$*"; }
warn()    { [ "${QUIET}" -eq 0 ] && printf "${YELLOW}[WARN]${NC} %s\n" "$*" >&2 || true; }
error()   { printf "${RED}[ERROR]${NC} %s\n" "$*" >&2; }
success() { [ "${QUIET}" -eq 0 ] && printf "${GREEN}[OK]${NC} %s\n" "$*"; }
msg()     { [ "${QUIET}" -eq 0 ] && printf "%s\n" "$*"; }
[ -t 0 ] && [ -t 1 ] && info "Interactive Mode"

empty_line() {  
    [ "${QUIET}" -eq 0 ] && echo "" >&2
}

double_line() { 
    [ "${QUIET}" -eq 0 ] && echo "==============================================================" >&2 
} 

STEP=1
step_message() {
    empty_line
    double_line
    [ "${QUIET}" -eq 0 ] && printf "${GREEN}%s.  %s${NC}\n" "$STEP" "$1" >&2
    double_line
    empty_line
    STEP=$((STEP + 1))
}

# =============================================================================
# is_installed() - Robust installation check
# =============================================================================
#
# GENERAL PURPOSE:
# Checks whether the script is already installed.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# =============================================================================

is_installed() {
    : "${GLOBAL_BIN:=/usr/local/bin}"
    : "${USER_BIN:=${HOME}/.local/bin}"
    : "${INSTALL_PATH:=${GLOBAL_BIN}/${APP_NAME}}"

    if [ -z "${IS_ROOT:-}" ]; then
        if [ "$(id -u)" -eq 0 ]; then
            IS_ROOT=1
        else
            IS_ROOT=0
        fi
    fi

    [ -f "${INSTALL_PATH}" ] && [ -x "${INSTALL_PATH}" ]
}

# =============================================================================
# get_installed_version() - Extract version from installed binary
# =============================================================================
#
# GENERAL PURPOSE:
# Safely reads the VERSION constant from the installed script.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# =============================================================================

get_installed_version() {
    local bin_path="${GLOBAL_BIN}/${APP_NAME}"

    if [ -x "$bin_path" ]; then
        grep '^VERSION="' "$bin_path" 2>/dev/null | cut -d'"' -f2 || echo "unknown"
    else
        echo "not installed"
    fi
}

# =============================================================================
# version_check() - Compare local vs remote version + suggest install
# =============================================================================
#
# GENERAL PURPOSE:
# Fetches the latest version from GitHub raw and compares with installed one.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# =============================================================================

version_check() {
    info "Checking latest version of ${APP_NAME}..."

    local remote_version
    remote_version=$(curl -fsSL "${SCRIPT_URL}" 2>/dev/null | grep '^VERSION="' | cut -d'"' -f2 || echo "")

    if [ -z "$remote_version" ]; then
        error "Failed to fetch remote version"
        return 1
    fi

    local local_version
    local_version=$(get_installed_version)

    printf "Local version : %s\n" "$local_version"
    printf "Latest version: %s\n\n" "$remote_version"

    if [ "$local_version" = "$remote_version" ]; then
        success "You are running the latest version."
        return 0
    elif [ "$local_version" = "not installed" ]; then
        warn "${APP_NAME} is not installed yet."
    else
        warn "A newer version is available (${remote_version})"
    fi
}

# =============================================================================
# self_update() - Perform self-update to latest version
# =============================================================================
#
# GENERAL PURPOSE:
# Downloads and installs the latest version from GitHub.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# =============================================================================

self_update() {
    info "Starting self-update of ${APP_NAME}..."

    local remote_version
    remote_version=$(curl -fsSL "${SCRIPT_URL}" 2>/dev/null | grep '^VERSION="' | cut -d'"' -f2 || echo "")

    if [ -z "$remote_version" ]; then
        error "Failed to fetch latest version"
        return 1
    fi

    local local_version
    local_version=$(get_installed_version)

    if [ "$local_version" = "$remote_version" ] && [ "${FORCE_REINSTALL}" -eq 0 ]; then
        success "Already running the latest version (${remote_version})."
        return 0
    fi

    if [ "$local_version" != "$remote_version" ]; then
        info "Updating from ${local_version} → ${remote_version}"
    fi

    FORCE_REINSTALL=1
    perform_self_install
}


# =============================================================================
# write_file_atomic() - Atomic file writing
# =============================================================================
#
# GENERAL PURPOSE:
# Write file safely using temporary file + atomic move.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# =============================================================================

write_file_atomic() {
    local target="$1"
    local tmp
    tmp=$(mktemp "${target}.XXXXXXXX") || die "mktemp failed"

    cat > "${tmp}" || { rm -f "${tmp}"; die "write failed"; }
    mv "${tmp}" "${target}" || { rm -f "${tmp}"; die "mv failed → ${target}"; }
}

# =============================================================================
# detect_external_ip() - Get public external IP (IPv4 ONLY)
# =============================================================================
#
# GENERAL PURPOSE:
# Returns the machine's public IPv4 address by querying external services.
# Never returns IPv6 addresses.
#
# !!! DO NOT MODIFY OR SIMPLIFY THIS FUNCTION !!!
# Changes are strictly limited to forcing IPv4 and defensive IPv6 rejection.
# =============================================================================

detect_external_ip() {
    local ip

    # Force IPv4-only on every request (-4 / --ipv4) to prevent IPv6 leakage
    # on dual-stack systems (common on cloud providers and modern networks).
    # Order of services kept exactly as before for minimal change.
    ip=$(curl -4 -fsSL https://ifconfig.me 2>/dev/null || \
         curl -4 -fsSL https://api.ipify.org 2>/dev/null || \
         echo "")

    # Extra defensive layer: reject anything that looks like IPv6
    # (contains ':' or starts with hex groups). This protects against
    # future service changes or network glitches that might still return IPv6.
    if echo "$ip" | grep -q ':' || [ -z "$ip" ]; then
        warn "Could not detect external IPv4 address automatically. Please enter manually."
        echo ""
        return 0
    fi

    echo "$ip"
}

# =============================================================================
# list_local_ips() - Show all network IPs on this machine
# =============================================================================
list_local_ips() {
    info "Listing all network interfaces and IP addresses on this machine:"
    echo ""
    ip -4 addr show | grep -E "inet " | awk '{print $2 "  " $NF}' | sed 's/\/.*//'
    echo ""
    info "External IP detected: $(detect_external_ip)"
    echo ""
}

# =============================================================================
# ip_conf_list() - List IPs in cluster
# =============================================================================
ip_conf_list() {
    if [ ! -f "${IP_CONF}" ]; then
        info "No cluster IP file found yet (${IP_CONF})"
        return 0
    fi
    info "Current cluster IPs:"
    cat "${IP_CONF}" | sed 's/^/  - /'
}

# =============================================================================
# ip_conf_add() - Add IP to cluster file
# =============================================================================
ip_conf_add() {
    local new_ip="$1"
    require_root
    ensure_config_dir

    if [ -z "$new_ip" ]; then
        error "No IP provided to add"
        return 1
    fi

    if grep -q "^${new_ip}$" "${IP_CONF}" 2>/dev/null; then
        warn "IP ${new_ip} is already in the cluster list"
        return 0
    fi

    echo "${new_ip}" >> "${IP_CONF}"
    success "Added IP ${new_ip} to cluster"
}

# =============================================================================
# ip_conf_remove() - Remove IP from cluster file
# =============================================================================
ip_conf_remove() {
    local rem_ip="$1"
    require_root
    ensure_config_dir

    if [ ! -f "${IP_CONF}" ]; then
        warn "No cluster IP file to remove from"
        return 1
    fi

    if ! grep -q "^${rem_ip}$" "${IP_CONF}" 2>/dev/null; then
        warn "IP ${rem_ip} not found in cluster list"
        return 1
    fi

    grep -v "^${rem_ip}$" "${IP_CONF}" > "${IP_CONF}.tmp" && mv "${IP_CONF}.tmp" "${IP_CONF}"
    success "Removed IP ${rem_ip} from cluster"
}

# =============================================================================
# debconf_noninteractive_mariadb() - Force non-interactive MariaDB install
# =============================================================================
debconf_noninteractive_mariadb() {
    require_root
    info "Pre-configuring MariaDB debconf for fully non-interactive install..."

    export DEBIAN_FRONTEND=noninteractive
    export DEBCONF_NONINTERACTIVE_SEEN=true

    # Pre-answer common MariaDB questions (including Feedback plugin)
    debconf-set-selections <<EOF
mariadb-server mysql-server/root_password password ''
mariadb-server mysql-server/root_password_again password ''
mariadb-server-11.8 mysql-server/root_password password ''
mariadb-server-11.8 mysql-server/root_password_again password ''
mariadb-server mariadb-server/root_password password ''
mariadb-server mariadb-server/root_password_again password ''
mariadb-server mariadb-server/feedback-plugin boolean false
mariadb-server-11.8 mariadb-server/feedback-plugin boolean false
EOF

    success "MariaDB debconf pre-configured (Feedback plugin disabled)"
}

# =============================================================================
# install_mariadb_galera() - Updated
# =============================================================================
install_mariadb_galera() {
    step_message "Installing MariaDB + Galera"
    require_root

    setup_mariadb_repo

    debconf_noninteractive_mariadb   # ← New call added here

    info "Installing mariadb-server, mariadb-client and galera-4..."
    
    apt-get install -y --no-install-recommends \
        mariadb-server \
        mariadb-client \
        "${GALERA_PACKAGE}" || die "Package installation failed"

    if command -v mariadb >/dev/null 2>&1; then
        success "MariaDB installed successfully"
        mariadb --version | head -n 1
    else
        die "MariaDB installation failed"
    fi
}

# =============================================================================
# generate_galera_config() - Create basic Galera config
# =============================================================================
generate_galera_config() {
    step_message "Generating Galera configuration"
    require_root
    ensure_config_dir

    if [ ! -f "${IP_CONF}" ] || [ ! -s "${IP_CONF}" ]; then
        warn "No IPs in cluster. Please add IPs first."
        return 1
    fi

    local cluster_ips
    cluster_ips=$(tr '\n' ',' < "${IP_CONF}" | sed 's/,$//')

    local current_ip
    current_ip=$(detect_external_ip)

    info "Generating /etc/mysql/conf.d/galera.cnf ..."

    write_file_atomic "/etc/mysql/conf.d/galera.cnf" <<EOF
[mysqld]
# Galera Cluster Configuration
wsrep_on=ON
wsrep_provider=/usr/lib/galera/libgalera_smm.so
wsrep_cluster_name="mariadb-galera-cluster"
wsrep_cluster_address="gcomm://${cluster_ips}"
wsrep_node_address="${current_ip}"
wsrep_node_name="$(hostname)"
wsrep_sst_method=rsync
wsrep_sst_auth="sst_user:sst_password"   # Change this in production!

# Basic settings
bind-address=0.0.0.0
default_storage_engine=InnoDB
innodb_autoinc_lock_mode=2
binlog_format=ROW
EOF

    success "Galera configuration generated"
    info "Cluster address: gcomm://${cluster_ips}"
}


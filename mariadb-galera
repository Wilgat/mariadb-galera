=============================================================================
# main()
# =============================================================================
main() {
    : "${HOME:=/root}"
    : "${GLOBAL_BIN:=/usr/local/bin}"

    local cmd="interactive"
    local ADD_IP=""
    local REMOVE_IP=""

    # =====================================================================
    # CRITICAL: Non-interactive mode detection (added fix)
    # =====================================================================
    if ! [ -t 0 ] || ! [ -t 1 ]; then
        # Running in pipe (curl | sudo sh) or non-interactive environment
        if [ -z "${1:-}" ]; then
            cmd="install"
            QUIET=${QUIET:-0}   # Allow quiet if user wants
            info "Non-interactive mode detected (pipe/curl execution) → forcing install-only mode"
        fi
    fi
    # =====================================================================

    while [ $# -gt 0 ]; do
        case "$1" in
            version|-v)
                cmd="version"
                ;;
            version-check)
                cmd="version-check"
                ;;
            self-update)
                cmd="self-update"
                ;;
            install)
                cmd="install"
                ;;
            list)
                cmd="list"
                ;;
            add)
                cmd="add"
                shift
                ADD_IP="${1:-}"
                ;;
            remove|del)
                cmd="remove"
                shift
                REMOVE_IP="${1:-}"
                ;;
            --force|--reinstall)
                FORCE_REINSTALL=1
                ;;
            --quiet|-q)
                QUIET=1
                ;;
            --help|-h)
                cmd="help"
                ;;
            --*)
                error "Unknown option: $1"
                printf "Try: %s --help\n" "$APP_NAME" >&2
                exit 1
                ;;
            *)
                error "Unknown argument: $1"
                printf "Try: %s --help\n" "$APP_NAME" >&2
                exit 1
                ;;
        esac
        shift
    done

    if [ "$cmd" = "version" ]; then
        printf "%s version %s\n" "${APP_NAME}" "${VERSION}"
        exit 0
    fi

    if [ "$cmd" = "version-check" ]; then
        version_check
        exit 0
    fi

    if [ "$cmd" = "self-update" ]; then
        require_root
        self_update
        exit 0
    fi

    if [ "$cmd" = "help" ]; then
        show_galera_help
        exit 0
    fi

    # Check installation for commands that need the script
    if ! is_installed; then
        maybe_install
        if ! is_installed; then
            exit 1
        fi
    fi

    case "${cmd}" in
        install)
            require_root
            step_message "Non-interactive installation"
            install_mariadb_galera
            ensure_config_dir
            success "MariaDB + Galera installed successfully."
            info "Run 'sudo ${APP_NAME}' for interactive cluster setup."
            ;;
        list)
            ip_conf_list
            ;;
        add)
            require_root
            if [ -n "${ADD_IP}" ]; then
                ip_conf_add "${ADD_IP}"
            else
                error "Usage: ${APP_NAME} add <ip>"
            fi
            ;;
        remove)
            require_root
            if [ -n "${REMOVE_IP}" ]; then
                ip_conf_remove "${REMOVE_IP}"
            else
                error "Usage: ${APP_NAME} remove <ip>"
            fi
            ;;
        interactive)
            require_root
            step_message "Starting interactive Galera cluster setup"

            ensure_config_dir
            list_local_ips

            ip_conf_list

            # Ask for current external IP
            local current_ip
            current_ip=$(detect_external_ip)
            printf "\nDetected external IP: %s\n" "${current_ip}"
            printf "Add this IP to cluster? (Y/n): "
            read -r answer || true
            if [ -z "$answer" ] || [[ "$answer" =~ ^[Yy] ]]; then
                ip_conf_add "${current_ip}"
            fi

            # Interactive add more IPs
            while true; do
                printf "\nAdd another cluster IP? (ip or Enter to skip): "
                read -r newip || true
                if [ -z "$newip" ]; then
                    break
                fi
                ip_conf_add "$newip"
            done

            # Remove IPs if wanted
            printf "\nWould you like to remove any IP? (y/N): "
            read -r rem || true
            if [[ "$rem" =~ ^[Yy] ]]; then
                ip_conf_list
                printf "Enter IP to remove: "
                read -r remip || true
                if [ -n "$remip" ]; then
                    ip_conf_remove "$remip"
                fi
            fi

            generate_galera_config

            # First node question
            printf "\nIs this the FIRST computer in the cluster? (y/N): "
            read -r first || true
            if [[ "$first" =~ ^[Yy] ]]; then
                success "Bootstrap this node with:"
                echo "    sudo galera_new_cluster"
            else
                success "Start this node with:"
                echo "    sudo systemctl start mariadb"
            fi

            empty_line
            success "Setup completed. Check status with: sudo systemctl status mariadb"
            info "Remember to open firewall port 3306, 4567, 4568, 4444 on all nodes."
            ;;
        *)
            die "Invalid command"
            ;;
    esac
}

main "$@"